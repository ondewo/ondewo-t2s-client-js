# ONDEWO Text-to-Speech (T2S) JS client -- examples configuration.
#
# Template with NON-SECRET placeholders. Copy real values in locally; do NOT commit secrets.
# Each example loads this file via dotenv (path resolved relative to the script), so the values
# below are read from process.env at runtime.

# --- Connection -------------------------------------------------------------------------------
# Host and port of the ONDEWO T2S gRPC-web endpoint (Envoy).
ONDEWO_HOST=localhost
ONDEWO_PORT=443

# --- Secure channel ---------------------------------------------------------------------------
# Use TLS (https) for the gRPC-web endpoint (true/false). Optional path to a custom CA/cert file.
ONDEWO_USE_SECURE_CHANNEL=true
ONDEWO_GRPC_CERT=

# --- Keycloak (bearer-token auth, 2FA-capable) ------------------------------------------------
# ROPC + offline_access login against the PUBLIC SDK client (no client secret for the public flow).
KEYCLOAK_URL=https://localhost/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# TLS certificate verification for the Keycloak token endpoint (true/false).
KEYCLOAK_VERIFY_SSL=true

# --- T2S service-specific ---------------------------------------------------------------------
# Id of the T2S pipeline that synthesizes the text (see ListT2sPipelines).
ONDEWO_T2S_PIPELINE_ID=default
# Text to synthesize in the example.
ONDEWO_T2S_TEXT=Hello from ONDEWO Text-to-Speech!
